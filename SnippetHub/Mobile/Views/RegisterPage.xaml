<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mobile.Views.RegisterPage"
             Title=""
             BackgroundColor="#0D0F14">

    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, Auto">

            <!-- Background decorative shapes -->
            <AbsoluteLayout Grid.RowSpan="3"
                            InputTransparent="True"
                            HeightRequest="900">
                <!-- Top-left glow orb -->
                <Ellipse
                    AbsoluteLayout.LayoutBounds="0.05, -0.02, 300, 300"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    Fill="#0E6E5A"
                    Opacity="0.32"/>
                <!-- Bottom-right glow orb -->
                <Ellipse
                    AbsoluteLayout.LayoutBounds="0.95, 1.02, 280, 280"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    Fill="#1A2A6C"
                    Opacity="0.40"/>
            </AbsoluteLayout>

            <!-- Top padding -->
            <BoxView Grid.Row="0"
                     HeightRequest="48"
                     Color="Transparent"/>

            <!-- Main Card -->
            <Border Grid.Row="1"
                    Margin="28,0"
                    Padding="32,36"
                    BackgroundColor="#13161E"
                    StrokeThickness="1"
                    Stroke="#2A2E3D"
                    StrokeShape="RoundRectangle 24">

                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,12" Radius="48" Opacity="0.6"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!-- Step indicator dots -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="6"
                                           Margin="0,0,0,24">
                        <Ellipse WidthRequest="28" HeightRequest="4" Fill="#4FCCB0"/>
                        <Ellipse WidthRequest="8"  HeightRequest="4" Fill="#2A2E3D"/>
                        <Ellipse WidthRequest="8"  HeightRequest="4" Fill="#2A2E3D"/>
                    </HorizontalStackLayout>

                    <!-- Icon -->
                    <Border HorizontalOptions="Center"
                            Padding="16"
                            BackgroundColor="#1E2330"
                            StrokeThickness="1"
                            Stroke="#2E3448"
                            StrokeShape="RoundRectangle 16"
                            Margin="0,0,0,24">
                        <Label Text="✧"
                               FontSize="28"
                               TextColor="#4FCCB0"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Title -->
                    <Label Text="Create account"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#F0F2F8"
                           HorizontalOptions="Center"
                           CharacterSpacing="-0.3"
                           Margin="0,0,0,6"/>

                    <!-- Subtitle -->
                    <Label Text="Fill in your details to get started"
                           FontSize="14"
                           TextColor="#6B7280"
                           HorizontalOptions="Center"
                           Margin="0,0,0,36"/>

                    <!-- ─── Name Row ─── -->
                    <Grid ColumnDefinitions="*, 12, *" Margin="0,0,0,0">

                        <!-- First Name -->
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="FIRST NAME"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#4FCCB0"
                                   CharacterSpacing="1.5"/>
                            <Border Padding="0"
                                    BackgroundColor="#1A1E2A"
                                    StrokeThickness="1"
                                    Stroke="#2A2E3D"
                                    StrokeShape="RoundRectangle 12">
                                <Entry x:Name="FirstNameEntry"
                                       Placeholder="John"
                                       PlaceholderColor="#3A3F50"
                                       TextColor="#E8EAF0"
                                       BackgroundColor="Transparent"
                                       FontSize="15"
                                       HeightRequest="52"
                                       Margin="14,0"
                                       ReturnType="Next"
                                       Keyboard="Text"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Last Name -->
                        <VerticalStackLayout Grid.Column="2" Spacing="8">
                            <Label Text="LAST NAME"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#4FCCB0"
                                   CharacterSpacing="1.5"/>
                            <Border Padding="0"
                                    BackgroundColor="#1A1E2A"
                                    StrokeThickness="1"
                                    Stroke="#2A2E3D"
                                    StrokeShape="RoundRectangle 12">
                                <Entry x:Name="LastNameEntry"
                                       Placeholder="Doe"
                                       PlaceholderColor="#3A3F50"
                                       TextColor="#E8EAF0"
                                       BackgroundColor="Transparent"
                                       FontSize="15"
                                       HeightRequest="52"
                                       Margin="14,0"
                                       ReturnType="Next"
                                       Keyboard="Text"/>
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Spacer -->
                    <BoxView HeightRequest="18" Color="Transparent"/>

                    <!-- Email -->
                    <Label Text="EMAIL"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#4FCCB0"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border Padding="0"
                            BackgroundColor="#1A1E2A"
                            StrokeThickness="1"
                            Stroke="#2A2E3D"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,0,18">
                        <Grid ColumnDefinitions="Auto, *" Padding="14,0">
                            <Label Grid.Column="0"
                                   Text="@"
                                   FontSize="16"
                                   TextColor="#4A5060"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0"/>
                            <Entry Grid.Column="1"
                                   x:Name="EmailEntry"
                                   Placeholder="john.doe@email.com"
                                   PlaceholderColor="#3A3F50"
                                   TextColor="#E8EAF0"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   HeightRequest="52"
                                   ReturnType="Next"
                                   Keyboard="Email"/>
                        </Grid>
                    </Border>

                    <!-- Username -->
                    <Label Text="USERNAME"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#4FCCB0"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border Padding="0"
                            BackgroundColor="#1A1E2A"
                            StrokeThickness="1"
                            Stroke="#2A2E3D"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,0,18">
                        <Grid ColumnDefinitions="Auto, *" Padding="14,0">
                            <Label Grid.Column="0"
                                   Text="#"
                                   FontSize="16"
                                   TextColor="#4A5060"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0"/>
                            <Entry Grid.Column="1"
                                   x:Name="UsernameEntry"
                                   Placeholder="johndoe"
                                   PlaceholderColor="#3A3F50"
                                   TextColor="#E8EAF0"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   HeightRequest="52"
                                   ReturnType="Next"
                                   Keyboard="Text"/>
                        </Grid>
                    </Border>

                    <!-- Password -->
                    <Label Text="PASSWORD"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#4FCCB0"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border Padding="0"
                            BackgroundColor="#1A1E2A"
                            StrokeThickness="1"
                            Stroke="#2A2E3D"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto, *" Padding="14,0">
                            <Label Grid.Column="0"
                                   Text="🔒"
                                   FontSize="15"
                                   TextColor="#4A5060"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0"/>
                            <Entry Grid.Column="1"
                                   x:Name="PasswordEntry"
                                   Placeholder="Create a strong password"
                                   PlaceholderColor="#3A3F50"
                                   TextColor="#E8EAF0"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   HeightRequest="52"
                                   IsPassword="True"
                                   ReturnType="Done"/>
                        </Grid>
                    </Border>

                    <!-- Password strength hint -->
                    <HorizontalStackLayout Spacing="4" Margin="2,0,0,28">
                        <BoxView WidthRequest="24" HeightRequest="3"
                                 Color="#4FCCB0"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <BoxView WidthRequest="24" HeightRequest="3"
                                 Color="#4FCCB0"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <BoxView WidthRequest="24" HeightRequest="3"
                                 Color="#2A2E3D"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <BoxView WidthRequest="24" HeightRequest="3"
                                 Color="#2A2E3D"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <Label Text="Medium strength"
                               FontSize="12"
                               TextColor="#6B7280"
                               VerticalOptions="Center"
                               Margin="4,0,0,0"/>
                    </HorizontalStackLayout>

                    <!-- Terms checkbox row -->
                    <HorizontalStackLayout Spacing="10" Margin="0,0,0,28">
                        <CheckBox x:Name="TermsCheckBox"
                                  Color="#4FCCB0"
                                  VerticalOptions="Center"/>
                        <Label VerticalOptions="Center"
                               FontSize="13">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="I agree to the "
                                          TextColor="#6B7280"/>
                                    <Span Text="Terms of Service"
                                          TextColor="#4FCCB0"
                                          FontAttributes="Bold"/>
                                    <Span Text=" and "
                                          TextColor="#6B7280"/>
                                    <Span Text="Privacy Policy"
                                          TextColor="#4FCCB0"
                                          FontAttributes="Bold"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Create Account Button -->
                    <Border BackgroundColor="#4FCCB0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,0,20">
                        <Border.Shadow>
                            <Shadow Brush="#4FCCB0" Offset="0,4" Radius="20" Opacity="0.35"/>
                        </Border.Shadow>
                        <Button x:Name="RegisterButton"
                                Text="CREATE ACCOUNT"
                                TextColor="#0D0F14"
                                FontAttributes="Bold"
                                FontSize="13"
                                CharacterSpacing="1.8"
                                BackgroundColor="Transparent"
                                HeightRequest="52"
                                CornerRadius="12"/>
                    </Border>

                    <!-- Divider -->
                    <Grid ColumnDefinitions="*, Auto, *" Margin="0,0,0,20">
                        <BoxView Grid.Column="0" Color="#2A2E3D" HeightRequest="1" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="or" TextColor="#3A3F50" FontSize="13" Margin="12,0"/>
                        <BoxView Grid.Column="2" Color="#2A2E3D" HeightRequest="1" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Login Link -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="Already have an account?"
                               TextColor="#6B7280"
                               FontSize="14"/>
                        <Label Text="Sign in"
                               TextColor="#4FCCB0"
                               FontSize="14"
                               FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Bottom padding -->
            <BoxView Grid.Row="2" HeightRequest="48" Color="Transparent"/>

        </Grid>
    </ScrollView>

</ContentPage>
